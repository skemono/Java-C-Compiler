(* prueba basica de lexer para C *)

let digit = ['0'-'9']
let letter = ['a'-'z''A'-'Z']
let id = letter(letter|digit)*

rule tokens =
    [' ' '\t' '\n']   { return WHITESPACE }
  | id                 { return ID }
  | digit+             { return NUMBER }
  | '+'                { return PLUS }
  | '-'                { return MINUS }
  | '='                { return EQUAL }
  | '['                { return LBRACKET }
  | ']'                { return RBRACKET }
