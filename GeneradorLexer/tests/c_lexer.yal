(* C Language Lexer — YALex specification *)

let digit    = ['0'-'9']
let lower    = ['a'-'z']
let upper    = ['A'-'Z']
let letter   = lower | upper
let alphanum = letter | digit
let hex      = ['0'-'9''a'-'f''A'-'F']
let ws       = [' ''\t''\n''\r']
let id       = (letter | '_')(alphanum | '_')*

rule tokens =
    ws+                  { }
  | "int"                { return INT }
  | "float"              { return FLOAT }
  | "char"               { return CHAR_TYPE }
  | "void"               { return VOID }
  | "if"                 { return IF }
  | "else"               { return ELSE }
  | "while"              { return WHILE }
  | "for"                { return FOR }
  | "return"             { return RETURN }
  | "struct"             { return STRUCT }
  | "typedef"            { return TYPEDEF }
  | "sizeof"             { return SIZEOF }
  | "break"              { return BREAK }
  | "continue"           { return CONTINUE }
  | id                   { return ID }
  | '0'("x"|"X")hex+    { return HEX_LIT }
  | digit+'.'digit+      { return FLOAT_LIT }
  | digit+               { return INT_LIT }
  | "=="                 { return EQ }
  | "!="                 { return NEQ }
  | "<="                 { return LEQ }
  | ">="                 { return GEQ }
  | "&&"                 { return AND }
  | "||"                 { return OR }
  | "++"                 { return INC }
  | "--"                 { return DEC }
  | "+="                 { return PLUS_ASSIGN }
  | "-="                 { return MINUS_ASSIGN }
  | "->"                 { return ARROW }
  | '+'                  { return PLUS }
  | '-'                  { return MINUS }
  | '*'                  { return STAR }
  | '/'                  { return DIV }
  | '%'                  { return MOD }
  | '<'                  { return LT }
  | '>'                  { return GT }
  | '='                  { return ASSIGN }
  | '!'                  { return NOT }
  | '&'                  { return AMP }
  | '|'                  { return PIPE }
  | '('                  { return LPAREN }
  | ')'                  { return RPAREN }
  | '{'                  { return LBRACE }
  | '}'                  { return RBRACE }
  | '['                  { return LBRACK }
  | ']'                  { return RBRACK }
  | ';'                  { return SEMI }
  | ','                  { return COMMA }
  | '.'                  { return DOT }
